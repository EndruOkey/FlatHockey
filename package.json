{
  "name": "flathockey-v4",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "dev:server": "npm run dev -w server",
    "dev:client": "npm run dev -w client",
    "build:client": "npm run build -w client",
    "build": "npm run build -w shared && npm run build -w server && npm run build -w client",
    "forbid:legacy-movement": "node scripts/forbid-legacy-movement.mjs",
    "itch:zip": "npm run build:client && node scripts/itch-zip.mjs",
    "ship:dev": "npm run itch:zip && git push origin dev",
    "start": "npm run start -w server"
  },
  "devDependencies": {
    "archiver": "^7.0.1",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
